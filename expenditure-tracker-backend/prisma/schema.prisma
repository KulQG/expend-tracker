generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Expenditure {
  id        Int      @id @default(autoincrement())
  name      String
  sum       Decimal  @db.Decimal(12, 2)
  date      DateTime
  createdAt DateTime @default(now())

  @@map("expenditures")
}
